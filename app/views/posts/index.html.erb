<% content_for :title, "Writing — Andrews Peprah" %>

<header class="page-head">
  <p class="eyebrow">Writing</p>
  <h1>Notes on building things</h1>
  <p class="lede">Engineering write-ups, infrastructure experiments, and the occasional debugging war story.</p>
</header>

<% if @posts.empty? %>
  <p class="muted">No posts yet — check back soon.</p>
<% else %>
  <ul class="post-list">
    <% @posts.each do |post| %>
      <li>
        <a href="<%= post_path(post) %>">
          <span class="post-date"><%= post.long_date %></span>
          <span class="post-title"><%= post.title %></span>
          <span class="post-desc"><%= post.description %></span>
          <span class="post-meta"><%= post.reading_minutes %> min read</span>
        </a>
      </li>
    <% end %>
  </ul>
<% end %>
