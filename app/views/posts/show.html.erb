<% content_for :title, "#{@post.title} — Andrews Peprah" %>
<% content_for :description, @post.description %>

<article class="article">
  <header class="article-head">
    <p class="eyebrow"><a href="<%= posts_path %>">← Writing</a></p>
    <h1><%= @post.title %></h1>
    <p class="article-meta">
      <time datetime="<%= @post.date.iso8601 %>"><%= @post.long_date %></time>
      <span class="dot">·</span>
      <%= @post.reading_minutes %> min read
    </p>
  </header>

  <div class="prose">
    <%= @post.html %>
  </div>

  <footer class="article-foot">
    <a href="<%= posts_path %>">← All writing</a>
    <a href="<%= root_path %>">Résumé →</a>
  </footer>
</article>
