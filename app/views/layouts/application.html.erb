<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <title><%= content_for(:title) || "Andrews Peprah" %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <% if content_for?(:description) %><meta name="description" content="<%= strip_tags(content_for(:description)) %>"><% end %>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <style>
      <%= rouge_css %>
      :root {
        --ink: #0f1b2d; --ink-2: #16263d; --paper: #f4f6f9; --card: #ffffff;
        --text: #1a2433; --muted: #5d6b7e; --muted-2: #8693a5;
        --accent: #c98a3a; --accent-ink: #95611a; --hair: rgba(26,36,51,0.12);
        --sans: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        --mono: ui-monospace, "SF Mono", "JetBrains Mono", Menlo, Consolas, "Liberation Mono", monospace;
      }
      * { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; }
      body { background: var(--paper); color: var(--text); font-family: var(--sans); font-size: 17px; line-height: 1.7; -webkit-font-smoothing: antialiased; }

      .topbar { background: var(--ink); color: #dde4ee; }
      .topbar .inner { max-width: 760px; margin: 0 auto; padding: 16px 24px; display: flex; align-items: center; justify-content: space-between; gap: 16px; }
      .topbar .brand { font-weight: 700; letter-spacing: -0.01em; color: #fff; text-decoration: none; font-size: 16px; }
      .topbar nav { display: flex; gap: 18px; font-family: var(--mono); font-size: 13px; }
      .topbar nav a { color: #aeb9c8; text-decoration: none; }
      .topbar nav a:hover { color: var(--accent); }

      .container { max-width: 760px; margin: 0 auto; padding: 56px 24px 72px; }
      .eyebrow { font-family: var(--mono); font-size: 12px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--accent-ink); margin: 0 0 12px; }
      .eyebrow a { color: var(--accent-ink); text-decoration: none; }
      .muted { color: var(--muted); }

      .page-head { margin-bottom: 40px; }
      .page-head h1 { font-size: clamp(32px, 5vw, 44px); line-height: 1.05; letter-spacing: -0.02em; margin: 0 0 12px; text-wrap: balance; }
      .page-head .lede { font-size: 18px; color: var(--muted); max-width: 56ch; margin: 0; }

      .post-list { list-style: none; margin: 0; padding: 0; }
      .post-list li { border-top: 1px solid var(--hair); }
      .post-list li:last-child { border-bottom: 1px solid var(--hair); }
      .post-list a { display: grid; gap: 4px; padding: 22px 4px; text-decoration: none; color: inherit; transition: padding-left 0.15s ease; }
      .post-list a:hover { padding-left: 10px; }
      .post-list .post-date { font-family: var(--mono); font-size: 12px; letter-spacing: 0.04em; color: var(--muted-2); text-transform: uppercase; }
      .post-list .post-title { font-size: 21px; font-weight: 700; letter-spacing: -0.01em; }
      .post-list a:hover .post-title { color: var(--accent-ink); }
      .post-list .post-desc { color: var(--muted); font-size: 15.5px; }
      .post-list .post-meta { font-family: var(--mono); font-size: 11.5px; color: var(--muted-2); margin-top: 2px; }

      .article-head { margin-bottom: 36px; }
      .article-head h1 { font-size: clamp(30px, 5vw, 42px); line-height: 1.08; letter-spacing: -0.02em; margin: 8px 0 14px; text-wrap: balance; }
      .article-meta { font-family: var(--mono); font-size: 13px; color: var(--muted); }
      .article-meta .dot { margin: 0 8px; color: var(--muted-2); }

      .prose { font-size: 17.5px; line-height: 1.75; color: #28303d; }
      .prose > * + * { margin-top: 1.15em; }
      .prose h2 { font-size: 25px; letter-spacing: -0.015em; margin-top: 1.9em; padding-top: 0.3em; border-top: 1px solid var(--hair); }
      .prose h3 { font-size: 20px; margin-top: 1.6em; }
      .prose h2, .prose h3 { line-height: 1.25; color: var(--text); }
      .prose a { color: var(--accent-ink); text-decoration: underline; text-decoration-color: rgba(149,97,26,0.4); text-underline-offset: 2px; }
      .prose a:hover { text-decoration-color: var(--accent-ink); }
      .prose strong { color: var(--text); }
      .prose ul, .prose ol { padding-left: 1.3em; }
      .prose li { margin: 0.35em 0; }
      .prose blockquote { margin: 1.4em 0; padding: 4px 18px; border-left: 3px solid var(--accent); color: var(--muted); font-style: italic; }
      .prose img { max-width: 100%; height: auto; border-radius: 8px; }
      .prose hr { border: 0; border-top: 1px solid var(--hair); margin: 2em 0; }

      .prose :not(pre) > code { font-family: var(--mono); font-size: 0.86em; background: rgba(15,27,45,0.06); border: 1px solid var(--hair); border-radius: 4px; padding: 0.1em 0.4em; color: #0f1b2d; }
      .prose pre, .prose .highlight { border-radius: 9px; padding: 16px 18px; overflow-x: auto; font-size: 14px; line-height: 1.55; margin: 1.4em 0; }
      .prose pre { font-family: var(--mono); }
      .prose pre code, .prose .highlight code { background: none; border: 0; padding: 0; font-size: inherit; color: inherit; }

      .prose table { width: 100%; border-collapse: collapse; font-size: 15px; display: block; overflow-x: auto; }
      .prose th, .prose td { text-align: left; padding: 8px 12px; border-bottom: 1px solid var(--hair); }
      .prose th { font-family: var(--mono); font-size: 12px; letter-spacing: 0.04em; text-transform: uppercase; color: var(--muted); }

      .article-foot { margin-top: 48px; padding-top: 20px; border-top: 1px solid var(--hair); display: flex; justify-content: space-between; font-family: var(--mono); font-size: 13px; }
      .article-foot a { color: var(--accent-ink); text-decoration: none; }

      :focus-visible { outline: 2px solid var(--accent); outline-offset: 3px; border-radius: 3px; }
      @media (max-width: 480px) { .container { padding: 36px 18px 56px; } }
    </style>
  </head>
  <body>
    <div class="topbar">
      <div class="inner">
        <a class="brand" href="<%= root_path %>">Andrews Peprah</a>
        <nav>
          <a href="<%= root_path %>">Résumé</a>
          <a href="<%= posts_path %>">Writing</a>
        </nav>
      </div>
    </div>
    <div class="container">
      <%= yield %>
    </div>
  </body>
</html>
