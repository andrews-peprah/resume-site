<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Andrews Peprah — Senior Software Engineer</title>
  <meta name="description" content="Andrews Peprah — Senior Software Engineer. 8+ years building scalable backends in Ruby on Rails and C#/.NET. West Vancouver, Canada.">
  <link rel="icon" href="/icon.svg" type="image/svg+xml">
  <style>
    :root {
      --ink: #0f1b2d; --ink-2: #16263d; --ink-line: rgba(255,255,255,0.10);
      --paper: #f4f6f9; --card: #ffffff; --text: #1a2433; --muted: #5d6b7e; --muted-2: #8693a5;
      --accent: #c98a3a; --accent-ink: #95611a; --hair: rgba(26,36,51,0.12);
      --sans: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
      --mono: ui-monospace, "SF Mono", "JetBrains Mono", Menlo, Consolas, "Liberation Mono", monospace;
      --maxw: 1180px;
    }
    * { box-sizing: border-box; }
    html, body { margin: 0; padding: 0; }
    body { background: var(--paper); color: var(--text); font-family: var(--sans); font-size: 16px; line-height: 1.6; -webkit-font-smoothing: antialiased; text-rendering: optimizeLegibility; }
    .wrap { max-width: var(--maxw); margin: 0 auto; display: grid; grid-template-columns: 340px 1fr; min-height: 100vh; background: var(--card); box-shadow: 0 1px 60px rgba(15,27,45,0.07); }
    .side { background: radial-gradient(900px 500px at -10% -5%, rgba(201,138,58,0.10), transparent 60%), linear-gradient(180deg, var(--ink) 0%, var(--ink-2) 100%); color: #dde4ee; padding: 48px 34px 44px; position: relative; }
    .side::before { content: ""; position: absolute; inset: 0; background-image: linear-gradient(var(--ink-line) 1px, transparent 1px), linear-gradient(90deg, var(--ink-line) 1px, transparent 1px); background-size: 26px 26px; opacity: 0.30; mask-image: linear-gradient(180deg, #000 0%, transparent 55%); -webkit-mask-image: linear-gradient(180deg, #000 0%, transparent 55%); pointer-events: none; }
    .side > * { position: relative; }
    .brandmark { font-family: var(--mono); font-size: 12px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--accent); margin-bottom: 30px; }
    .side-block { margin-bottom: 30px; } .side-block:last-child { margin-bottom: 0; }
    .side-label { font-family: var(--mono); font-size: 10.5px; letter-spacing: 0.20em; text-transform: uppercase; color: var(--muted-2); margin: 0 0 12px; padding-bottom: 8px; border-bottom: 1px solid var(--ink-line); }
    .contact-list, .plain-list { list-style: none; margin: 0; padding: 0; }
    .contact-list li { margin-bottom: 9px; font-size: 13.5px; line-height: 1.5; word-break: break-word; }
    .contact-list a { color: #e7ecf3; text-decoration: none; }
    .contact-list a:hover { color: var(--accent); }
    .contact-list .k { font-family: var(--mono); font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--muted-2); display: block; }
    .chips { display: flex; flex-wrap: wrap; gap: 7px; }
    .chip { font-size: 12px; font-family: var(--mono); color: #cfd8e4; border: 1px solid var(--ink-line); background: rgba(255,255,255,0.03); border-radius: 4px; padding: 4px 9px; }
    .chip.lead { color: var(--ink); background: var(--accent); border-color: var(--accent); font-weight: 600; }
    .plain-list li { font-size: 13px; color: #c3cdda; padding: 6px 0; border-bottom: 1px dashed var(--ink-line); display: flex; justify-content: space-between; gap: 12px; }
    .plain-list li:last-child { border-bottom: 0; }
    .plain-list .meta { color: var(--muted-2); font-family: var(--mono); font-size: 11px; white-space: nowrap; }
    .lang-row { display:flex; justify-content: space-between; align-items: baseline; gap: 10px; padding: 6px 0; border-bottom: 1px dashed var(--ink-line); font-size: 13.5px; }
    .lang-row:last-child { border-bottom: 0; }
    .lang-row .lvl { font-family: var(--mono); font-size: 10.5px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--muted-2); }
    .main { padding: 56px 60px 64px; }
    .hero { margin-bottom: 30px; }
    .eyebrow { font-family: var(--mono); font-size: 12px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--accent-ink); margin: 0 0 14px; }
    h1 { font-size: clamp(38px, 6vw, 58px); line-height: 1.02; letter-spacing: -0.022em; font-weight: 800; margin: 0 0 14px; text-wrap: balance; }
    .role { font-size: 18px; color: var(--muted); margin: 0 0 4px; font-weight: 500; }
    .role b { color: var(--text); font-weight: 700; }
    .loc { font-family: var(--mono); font-size: 12.5px; color: var(--muted-2); letter-spacing: 0.02em; }
    .accent-rule { width: 56px; height: 3px; background: var(--accent); border: 0; margin: 26px 0; border-radius: 2px; }
    .summary { font-size: 17px; line-height: 1.66; color: #303d4f; max-width: 60ch; }
    .summary strong { color: var(--text); }
    .section { margin-top: 46px; }
    .section-head { display: flex; align-items: center; gap: 14px; margin-bottom: 26px; }
    .section-head h2 { font-size: 14px; font-family: var(--mono); letter-spacing: 0.16em; text-transform: uppercase; color: var(--text); margin: 0; font-weight: 600; }
    .section-head .line { flex: 1; height: 1px; background: var(--hair); }
    .timeline { position: relative; padding-left: 26px; }
    .timeline::before { content: ""; position: absolute; left: 5px; top: 6px; bottom: 6px; width: 2px; background: linear-gradient(180deg, var(--accent), var(--hair)); }
    .job { position: relative; padding-bottom: 30px; } .job:last-child { padding-bottom: 0; }
    .job::before { content: ""; position: absolute; left: -24.5px; top: 7px; width: 11px; height: 11px; border-radius: 50%; background: var(--accent); box-shadow: 0 0 0 4px var(--card), 0 0 0 5px var(--hair); }
    .job-top { display: flex; flex-wrap: wrap; align-items: baseline; gap: 6px 12px; }
    .job-role { font-size: 18px; font-weight: 700; letter-spacing: -0.01em; }
    .job-co { font-size: 18px; font-weight: 700; color: var(--accent-ink); }
    .job-co::before { content: "· "; color: var(--muted-2); font-weight: 400; }
    .job-meta { font-family: var(--mono); font-size: 12px; color: var(--muted); font-variant-numeric: tabular-nums; margin: 5px 0 12px; }
    .job-meta .sep { color: var(--muted-2); margin: 0 8px; }
    .job ul { margin: 0; padding-left: 0; list-style: none; }
    .job li { position: relative; padding-left: 18px; margin-bottom: 6px; font-size: 14.5px; color: #3a4658; line-height: 1.55; max-width: 68ch; }
    .job li::before { content: ""; position: absolute; left: 2px; top: 9px; width: 5px; height: 5px; border: 1.5px solid var(--accent); border-radius: 50%; }
    .stackline { font-family: var(--mono); font-size: 12.5px; color: var(--muted); margin: 4px 0 10px; }
    .stackline b { color: var(--accent-ink); font-weight: 600; }
    .job.compact .job-role, .job.compact .job-co { font-size: 16px; }
    .writing-card { margin-top: 16px; background: var(--ink); color: #dde4ee; border-radius: 10px; padding: 22px 24px; display: block; text-decoration: none; position: relative; overflow: hidden; transition: transform 0.18s ease, box-shadow 0.18s ease; }
    .writing-card:hover { transform: translateY(-2px); box-shadow: 0 14px 34px rgba(15,27,45,0.20); }
    .writing-card .tag { font-family: var(--mono); font-size: 10.5px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--accent); }
    .writing-card .wt { font-size: 18px; font-weight: 700; color: #fff; margin: 8px 0 6px; letter-spacing: -0.01em; }
    .writing-card .wd { font-size: 13.5px; color: #aeb9c8; max-width: 56ch; }
    .writing-card .go { font-family: var(--mono); font-size: 12px; color: var(--accent); margin-top: 12px; display: inline-block; }
    footer { margin-top: 54px; padding-top: 20px; border-top: 1px solid var(--hair); font-family: var(--mono); font-size: 11.5px; letter-spacing: 0.04em; color: var(--muted-2); display: flex; justify-content: space-between; flex-wrap: wrap; gap: 8px; }
    footer a { color: var(--accent-ink); text-decoration: none; }
    :focus-visible { outline: 2px solid var(--accent); outline-offset: 3px; border-radius: 3px; }
    .reveal { opacity: 0; transform: translateY(12px); animation: rise 0.6s cubic-bezier(.2,.7,.3,1) forwards; }
    .d1{animation-delay:.05s}.d2{animation-delay:.13s}.d3{animation-delay:.22s}
    @keyframes rise { to { opacity: 1; transform: none; } }
    @media (prefers-reduced-motion: reduce) { .reveal { animation: none; opacity: 1; transform: none; } .writing-card { transition: none; } }
    @media (max-width: 860px) { .wrap { grid-template-columns: 1fr; } .side { padding: 40px 28px 36px; } .main { padding: 40px 28px 48px; } }
    @media (max-width: 480px) { .main { padding: 32px 20px 40px; } .job-meta .sep { display: none; } }
  </style>
</head>
<body>
  <%= yield %>
</body>
</html>
