#!/bin/bash -e

# Enable jemalloc for reduced memory usage and latency.
if [ -z "${LD_PRELOAD+x}" ]; then
    LD_PRELOAD=$(find /usr/lib -name libjemalloc.so.2 -print -quit)
    export LD_PRELOAD
fi

# Prepare the SQLite database (create + migrate; seeds run only on first create)
# when booting the web server. New writings added later persist in the volume.
if [ "${1}" = "./bin/rails" ] && [ "${2}" = "server" ]; then
    ./bin/rails db:prepare
fi

exec "${@}"
